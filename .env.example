ANTHROPIC_API_KEY=sk-ant-your-key-here

# Base64-encoded scoring brief (used in CI/GitHub Actions instead of the local file)
# Generate with: cat profile/scoring-brief.md | base64
# SCORING_BRIEF_B64=

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Discord webhook for pipeline error alerts (separate channel)
DISCORD_ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/your-error-webhook-url

# Database backend: "local" (default) or "turso"
DB_BACKEND=local
# Turso (only needed when DB_BACKEND=turso)
# TURSO_DATABASE_URL=libsql://job-monitor-{username}.turso.io
# TURSO_AUTH_TOKEN=eyJ...
